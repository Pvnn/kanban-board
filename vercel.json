{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/api"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/index.js"
    },
    {
      "source": "/auth/(.*)",
      "destination": "backend/index.js"
    },
    {
      "source": "/((?!api|auth).*)",
      "destination": "/index.html"
    }
  ]
}