generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  projects  Project[]
  createdAt DateTime  @default(now())
}

model Project {
  id        String   @id @default(uuid())
  name      String
  members   User[]
  tasks     Task[]
  createdAt DateTime @default(now())
}

model Task {
  id        String   @id @default(uuid())
  title     String
  status    String
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
  projectId String
}
